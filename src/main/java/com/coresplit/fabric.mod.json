{
    "schemaVersion": 1,
    "id": "coresplit",
    "version": "${version}",
    "name": "CoreSplit",
    "description": "Parallel tick engine for Minecraft — distributes game processes across CPU cores for maximum performance.",
    "authors": [
        "DR.Kyusu"
    ],
    "contact": {
        "sources": "https://github.com/DrKyusu/CoreSplit",
        "issues": "https://github.com/DrKyusu/CoreSplit/issues"
    },
    "license": "AGPL-3.0 license",
    "icon": "assets/coresplit/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "com.coresplit.CoreSplitMod"
        ],
        "server": [
            "com.coresplit.CoreSplitMod"
        ]
    },
    "mixins": [
        "coresplit.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.19.3",
        "fabric-api": "*",
        "minecraft": "26.2",
        "java": ">=21"
    },
    "suggests": {
        "lithium": "*",
        "sodium": "*"
    }
}